{
  "manifest_version": 3,
  "name": "HN Comments Reader",
  "version": "0.1",
  "description": "Drill-down Hacker News threads with markdown rendering.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "HN Comments Reader"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://news.ycombinator.com/item*"],
      "js": ["vendor/marked.min.js", "vendor/purify.min.js", "markdown.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ]
}
